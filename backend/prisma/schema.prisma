generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  NORMAL_USER
  STORE_OWNER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  address   String?
  role      Role     @default(NORMAL_USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings   Rating[]
  stores    Store[]  @relation("StoreOwner")
}

model Store {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  address   String
  ownerId   String
  owner     User     @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ratings   Rating[]
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  rating    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId]) // Ensures one rating per user per store
}
